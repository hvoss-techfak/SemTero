# Zotero settings
ZOTERO_API_URL=http://127.0.0.1:23119
# ZOTERO_API_KEY=your_api_key_here
# ZOTERO_LIBRARY_ID=your_library_id

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
RERANKER_MODEL=dengcao/Qwen3-Reranker-0.6B:Q8_0

# Embedding dimensions (0 = auto-detect)
EMBEDDING_DIMENSIONS=128

# Storage paths
VECTOR_STORE_DIR=./data/vector_store
PDF_CACHE_PATH=./data/pdfs

# Embedding options
AUTO_EMBED_SENTENCES=false

# Threading for embedding
MAX_EMBEDDING_WORKERS=4

# Batch embedding settings
BATCH_EMBEDDING_SIZE=32

# PDF processing options
PAGE_SPLITS=4